rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      // Para prototipado, permitimos acciones administrativas a usuarios autenticados
      // o verificamos la colección de roles si existe.
      return isSignedIn();
    }

    function isCircleAdmin(adminId) {
      return isSignedIn() && (request.auth.uid == adminId || isGlobalAdmin());
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isValidUserRef(userId) {
      return request.resource.data.userId == userId;
    }

    // Regla para consultas de Collection Group (necesaria para la administración de miembros)
    match /{path=**}/saving_circle_memberships/{membershipId} {
      allow list: if isGlobalAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isGlobalAdmin();
      allow list: if isOwner(userId) || isGlobalAdmin();
      allow create: if isOwner(userId);
      allow update: if (isExistingOwner(userId) || isGlobalAdmin()) && (request.resource.data.id == resource.data.id);
      allow delete: if isExistingOwner(userId) || isGlobalAdmin();

      match /saving_circle_memberships/{membershipId} {
        allow get, list: if isOwner(userId) || isGlobalAdmin();
        allow create: if isOwner(userId) && isValidUserRef(userId);
        allow update: if (isExistingOwner(userId) || isGlobalAdmin());
        allow delete: if isExistingOwner(userId) || isGlobalAdmin();
      }
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isGlobalAdmin();
      allow create, update, delete: if isGlobalAdmin();
    }

    match /saving_circles/{savingCircleId} {
      // Permitir exploración pública para que visitantes vean los planes
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if (isCircleAdmin(resource.data.adminUserId) || isGlobalAdmin());
      allow delete: if isGlobalAdmin();

      match /bids/{bidId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && isValidUserRef(request.auth.uid);
        allow update: if isGlobalAdmin();
        allow delete: if isGlobalAdmin();
      }

      match /adjudication_events/{eventId} {
        allow get, list: if isSignedIn();
        allow create: if isGlobalAdmin();
        allow update: if isGlobalAdmin();
        allow delete: if isGlobalAdmin();
      }
    }

    match /static_content_pages/{pageId} {
      allow get, list: if true;
      allow create, update, delete: if isGlobalAdmin();
    }
  }
}