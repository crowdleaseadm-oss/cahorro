rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones auxiliares de seguridad
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGLAS PARA COLLECTION GROUPS ---
    // Estas reglas son críticas para que las consultas 'collectionGroup' funcionen.
    // Permiten buscar en todas las subcolecciones con estos nombres en toda la BD.
    
    match /{path=**}/saving_circle_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    match /{path=**}/bids/{bidId} {
      allow read, write: if isSignedIn();
    }

    // --- REGLAS POR COLECCIÓN ESPECÍFICA ---

    // Usuarios y sus membresías privadas
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId) || isSignedIn();
      allow delete: if isSignedIn();

      match /saving_circle_memberships/{membershipId} {
        // Permitir acceso directo si se conoce la ruta
        allow read, write: if isSignedIn();
      }
    }

    // Círculos de ahorro
    match /saving_circles/{circleId} {
      // Los planes son públicos para fomentar la suscripción
      allow read: if true;
      // Cualquier usuario autenticado puede gestionar en este prototipo
      allow create, update, delete: if isSignedIn();

      match /bids/{bidId} {
        allow read, write: if isSignedIn();
      }
    }

    // Contenido estático
    match /static_content_pages/{pageId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}