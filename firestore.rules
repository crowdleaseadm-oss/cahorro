rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGLAS PARA CONSULTAS DE GRUPO (collectionGroup)
    // Estas reglas deben ser globales para que Firestore permita listar documentos 
    // a través de múltiples rutas de usuario.
    
    match /{path=**}/saving_circle_memberships/{membershipId} {
      allow read, list, write: if request.auth != null;
    }

    match /{path=**}/bids/{bidId} {
      allow read, list, write: if request.auth != null;
    }

    // Reglas para Círculos de Ahorro (Exploración pública)
    match /saving_circles/{circleId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /bids/{bidId} {
        allow read, write: if request.auth != null;
      }
    }

    // Permisos generales para el resto de la base de datos (Perfiles de usuario, etc.)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}