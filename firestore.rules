rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      // Para prototipado, permitimos acciones administrativas a usuarios autenticados.
      return isSignedIn();
    }

    function isCircleAdmin(adminId) {
      return isSignedIn() && (request.auth.uid == adminId || isGlobalAdmin());
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isValidUserRef(userId) {
      return request.resource.data.userId == userId;
    }

    // --- REGLAS PARA COLLECTION GROUPS ---
    // Estas reglas permiten consultas que atraviesan todos los documentos con el mismo nombre de subcolección.
    
    match /{path=**}/saving_circle_memberships/{membershipId} {
      // Permite listar miembros de cualquier círculo si el usuario está autenticado.
      allow list, get: if isSignedIn();
    }

    match /{path=**}/bids/{bidId} {
      // Permite listar licitaciones de cualquier círculo si el usuario está autenticado.
      allow list, get: if isSignedIn();
    }

    // --- REGLAS POR COLECCIÓN ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isGlobalAdmin();
      allow list: if isGlobalAdmin();
      allow create: if isOwner(userId);
      allow update: if (isExistingOwner(userId) || isGlobalAdmin());
      allow delete: if isGlobalAdmin();

      match /saving_circle_memberships/{membershipId} {
        allow get, list: if isOwner(userId) || isGlobalAdmin();
        allow create: if isOwner(userId) && isValidUserRef(userId);
        allow update: if isOwner(userId) || isGlobalAdmin();
        allow delete: if isGlobalAdmin();
      }
    }

    match /saving_circles/{savingCircleId} {
      // Exploración pública
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Simplificado para prototipado
      allow delete: if isGlobalAdmin();

      match /bids/{bidId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && isValidUserRef(request.auth.uid);
        allow update: if isGlobalAdmin();
        allow delete: if isGlobalAdmin();
      }

      match /adjudication_events/{eventId} {
        allow get, list: if isSignedIn();
        allow create: if isGlobalAdmin();
        allow update: if isGlobalAdmin();
        allow delete: if isGlobalAdmin();
      }
    }

    match /static_content_pages/{pageId} {
      allow get, list: if true;
      allow create, update, delete: if isGlobalAdmin();
    }
  }
}