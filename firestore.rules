rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones auxiliares de seguridad
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGLAS PARA COLLECTION GROUPS ---
    // Indispensables para que las consultas 'collectionGroup' funcionen.
    // Permiten buscar a través de todas las subcolecciones con estos nombres.
    
    match /{path=**}/saving_circle_memberships/{membershipId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{path=**}/bids/{bidId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- REGLAS POR COLECCIÓN ESPECÍFICA ---

    // Usuarios y sus membresías privadas
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId) || isSignedIn();
      allow delete: if isSignedIn();

      match /saving_circle_memberships/{membershipId} {
        allow read, write: if isSignedIn();
      }
    }

    // Círculos de ahorro y sus licitaciones
    match /saving_circles/{circleId} {
      // Los planes son públicos para fomentar la suscripción
      allow read: if true;
      // Cualquier usuario autenticado puede crear o gestionar (estilo admin para prototipo)
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();

      match /bids/{bidId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
      }
    }

    // Contenido estático
    match /static_content_pages/{pageId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}