rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGLA CRÍTICA: Permite consultas de Grupo de Colección (collectionGroup)
    // Esto es necesario para listar miembros de un círculo desde el panel admin
    match /{path=**}/saving_circle_memberships/{membershipId} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Reglas para Círculos de Ahorro
    match /saving_circles/{circleId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /bids/{bidId} {
        allow read, write: if request.auth != null;
      }
    }

    // Perfiles de Usuario
    match /users/{userId} {
      allow read, write: if request.auth != null;
      
      match /saving_circle_memberships/{membershipId} {
        allow read, write: if request.auth != null;
      }
    }

    // Regla de respaldo para cualquier otro documento
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}