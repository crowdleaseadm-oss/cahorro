rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGLA CRÍTICA PARA CONSULTAS DE GRUPO (collectionGroup)
    // Debe estar fuera de cualquier otro bloque match específico para funcionar correctamente
    match /{path=**}/saving_circle_memberships/{membershipId} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /{path=**}/bids/{bidId} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Reglas para Círculos de Ahorro (Exploración pública)
    match /saving_circles/{circleId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /bids/{bidId} {
        allow read, write: if request.auth != null;
      }
    }

    // Perfiles de Usuario y sus subcolecciones
    match /users/{userId} {
      allow read, write: if request.auth != null;
      
      match /{allChildren=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Regla de respaldo para cualquier otro documento
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}