rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para Círculos de Ahorro (Públicos para lectura)
    match /saving_circles/{circleId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /bids/{bidId} {
        allow read, write: if request.auth != null;
      }
    }

    // Regla global para usuarios autenticados
    // Permite consultas de collectionGroup (como saving_circle_memberships) sin errores
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}