
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // REGLAS PARA CONSULTAS DE GRUPO (Collection Group)
    // Deben estar fuera de los bloques de ruta específicos para ser detectadas globalmente.
    match /{path=**}/saving_circle_memberships/{membershipId} {
      allow read, write: if request.auth != null;
    }

    match /{path=**}/bids/{bidId} {
      allow read, write: if request.auth != null;
    }

    // Perfiles de Usuario
    match /users/{userId} {
      allow get, list: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      match /saving_circle_memberships/{membershipId} {
        allow read, write: if request.auth != null;
      }
    }

    // Círculos de Ahorro
    match /saving_circles/{circleId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /bids/{bidId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
