rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para Círculos de Ahorro (Exploración pública)
    match /saving_circles/{circleId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      // Subcolección de ofertas/licitaciones
      match /bids/{bidId} {
        allow read, write: if request.auth != null;
      }

      // NUEVA: Subcolección de miembros dentro del círculo (para administración eficiente)
      match /members/{memberId} {
        allow read, write: if request.auth != null;
      }
    }

    // Perfiles de usuario y sus membresías personales
    match /users/{userId} {
      allow read, write: if request.auth != null;
      
      match /saving_circle_memberships/{membershipId} {
        allow read, write: if request.auth != null;
      }
    }

    // Regla global de respaldo para usuarios autenticados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}