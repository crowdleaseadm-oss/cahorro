rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isCircleAdmin(adminId) {
      return isSignedIn() && request.auth.uid == adminId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isValidUserRef(userId) {
      return request.resource.data.userId == userId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isGlobalAdmin();
      allow list: if isOwner(userId) || isGlobalAdmin();
      allow create: if isOwner(userId);
      allow update: if (isExistingOwner(userId) || isGlobalAdmin()) && (request.resource.data.id == resource.data.id);
      allow delete: if isExistingOwner(userId) || isGlobalAdmin();

      match /saving_circle_memberships/{membershipId} {
        allow get, list: if isOwner(userId) || isCircleAdmin(resource.data.savingCircleAdminUserId) || isGlobalAdmin();
        allow create: if isOwner(userId) && isValidUserRef(userId);
        allow update: if (isExistingOwner(userId) || isCircleAdmin(resource.data.savingCircleAdminUserId) || isGlobalAdmin()) && (request.resource.data.userId == resource.data.userId);
        allow delete: if isExistingOwner(userId) || isCircleAdmin(resource.data.savingCircleAdminUserId) || isGlobalAdmin();

        match /payments/{paymentId} {
          allow get, list: if isOwner(userId) || isCircleAdmin(resource.data.savingCircleAdminUserId) || isGlobalAdmin();
          allow create: if isOwner(userId) || isCircleAdmin(request.resource.data.savingCircleAdminUserId) || isGlobalAdmin();
          allow update: if (isExistingOwner(userId) || isCircleAdmin(resource.data.savingCircleAdminUserId) || isGlobalAdmin());
          allow delete: if isGlobalAdmin();
        }
      }
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isGlobalAdmin();
      allow create, update, delete: if isGlobalAdmin();
    }

    match /saving_circles/{savingCircleId} {
      allow get, list: if isSignedIn();
      allow create: if isGlobalAdmin();
      allow update: if (isCircleAdmin(resource.data.adminUserId) || isGlobalAdmin()) && (request.resource.data.adminUserId == resource.data.adminUserId);
      allow delete: if isGlobalAdmin();

      match /adjudication_events/{eventId} {
        allow get, list: if isSignedIn();
        allow create: if isCircleAdmin(request.resource.data.savingCircleAdminUserId) || isGlobalAdmin();
        allow update: if (isCircleAdmin(request.resource.data.savingCircleAdminUserId) || isGlobalAdmin());
        allow delete: if isGlobalAdmin();
      }
    }

    match /static_content_pages/{pageId} {
      allow get, list: if true;
      allow create, update, delete: if isGlobalAdmin();
    }
  }
}