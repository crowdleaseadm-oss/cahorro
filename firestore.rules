
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones de utilidad
    function isSignedIn() {
      return request.auth != null;
    }

    // REGLAS PARA CONSULTAS DE GRUPO (Collection Group)
    // Estas reglas DEBEN estar en la raíz para permitir consultas globales
    match /{allPaths=**}/saving_circle_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    match /{allPaths=**}/bids/{bidId} {
      allow read, write: if isSignedIn();
    }

    // Perfiles de Usuario
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;

      match /saving_circle_memberships/{membershipId} {
        allow read, write: if isSignedIn();
      }
    }

    // Círculos de Ahorro
    match /saving_circles/{circleId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();

      match /bids/{bidId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
