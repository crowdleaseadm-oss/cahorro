rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regla Maestra por Email y DNI (Prioridad Máxima)
    match /{allPaths=**} {
      allow read, write: if request.auth != null && 
        request.auth.token.email != null &&
        (request.auth.token.email.lower() == 'crowd.lease.adm@gmail.com' || 
         request.auth.token.email.lower() == 'admin@circulodeahorro.com');
    }

    // Funciones de utilidad
    function isCEO() {
      return request.auth != null && 
        ((request.auth.token.email != null && request.auth.token.email.lower() == 'crowd.lease.adm@gmail.com') || 
         getRole() == 'ceo');
    }

    function isAdmin() {
      return request.auth != null && 
        ((request.auth.token.email != null && request.auth.token.email.lower() == 'crowd.lease.adm@gmail.com') || 
         getRole() == 'admin' || getRole() == 'ceo');
    }

    function isAuditor() {
      return request.auth != null && getRole() == 'auditor';
    }

    function canReadAdminData() {
      return isAdmin() || isAuditor();
    }

    function getRole() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.role : 'user';
    }

    // Reglas para colecciones
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || canReadAdminData());
      allow update, create: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isCEO();
      
      match /saving_circle_memberships/{membershipId} {
        allow read: if request.auth != null && (request.auth.uid == userId || canReadAdminData());
        allow update, create: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow delete: if isCEO();
        
        match /logs/{logId} {
          allow read: if request.auth != null && (request.auth.uid == userId || canReadAdminData());
          allow create, update: if request.auth != null && (request.auth.uid == userId || isAdmin());
          allow delete: if isCEO();
        }
      }

    }
    
    // Reglas para Cuentas Bancarias (Movidas al nivel superior por seguridad de alcance)
    match /users/{userId}/bank_accounts/{accountId} {
      allow list, get: if request.auth != null && (request.auth.uid == userId || canReadAdminData());
      allow create, update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == userId || isCEO());
    }

    match /saving_circles/{circleId} {
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update: if request.auth != null && (
        isAdmin() || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentMemberCount', 'accumulatedCommonFund']) &&
          (!('memberCapacity' in resource.data) || request.resource.data.currentMemberCount <= resource.data.memberCapacity)
        )
      );
      allow delete: if isCEO();
      
      match /bids/{bidId} {
        allow read, write: if request.auth != null;
        allow delete: if isCEO();
      }

      match /members/{memberId} {
        allow read: if request.auth != null;
        allow update, create: if request.auth != null && (request.auth.uid == memberId || isAdmin());
        allow delete: if isCEO();
      }
    }

    match /app_configurations/{configId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isCEO();
    }
    
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
      allow delete: if isCEO();
    }

    match /admin_requests/{requestId} {
      allow read: if canReadAdminData();
      allow create, update: if request.auth != null;
      allow delete: if isCEO();
    }
  }
}