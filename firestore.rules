rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. REGLAS PRIORITARIAS PARA GRUPOS DE COLECCIONES (Collection Group)
    // Estas reglas DEBEN estar al principio y usar sintaxis de comodín de ruta completa.
    // Permiten que el administrador busque socios y licitaciones en toda la base de datos.
    
    match /{path=**}/saving_circle_memberships/{membershipId} {
      allow read, write: if request.auth != null;
    }

    match /{path=**}/bids/{bidId} {
      allow read, write: if request.auth != null;
    }

    // 2. REGLAS POR RUTA ESPECÍFICA (Colecciones principales)

    // Usuarios y perfiles
    match /users/{userId} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;

      // Acceso directo a membresías si se conoce la ruta
      match /saving_circle_memberships/{membershipId} {
        allow read, write: if request.auth != null;
      }
    }

    // Círculos de ahorro
    match /saving_circles/{circleId} {
      // Los planes son públicos para permitir la exploración antes del login
      allow read: if true;
      // Cualquier usuario autenticado puede gestionar en este prototipo
      allow write: if request.auth != null;

      match /bids/{bidId} {
        allow read, write: if request.auth != null;
      }
    }

    // Páginas de contenido estático
    match /static_content_pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}