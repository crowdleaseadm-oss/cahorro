
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the Círculo de Ahorro application.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "registrationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "registrationDate"]
    },
    "SavingCircle": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SavingCircle",
      "type": "object",
      "description": "Represents a collective saving circle (Círculo de Ahorro) with specific financial parameters in USD.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "adminUserId": { "type": "string" },
        "targetCapital": { "type": "number", "description": "Capital suscripto (multiplo de 5000 USD)." },
        "totalInstallments": { "type": "number" },
        "installmentValue": { "type": "number", "description": "Alicuota pura." },
        "subscriptionFeeRate": { "type": "number" },
        "administrativeFeeRate": { "type": "number" },
        "lifeInsuranceRate": { "type": "number", "default": 0.0009 },
        "subscriptionVatApplied": { "type": "boolean", "default": true },
        "adminVatApplied": { "type": "boolean", "default": true },
        "lifeInsuranceVatApplied": { "type": "boolean", "default": false },
        "drawMethodCount": { "type": "number", "description": "0-5 adjudicaciones por sorteo." },
        "bidMethodCount": { "type": "number", "description": "0-5 adjudicaciones por licitacion." },
        "memberCapacity": { "type": "number" },
        "currentMemberCount": { "type": "number", "default": 0 },
        "status": { "type": "string", "enum": ["Active", "Completed", "Cancelled"] },
        "isPrivate": { "type": "boolean", "default": false },
        "password": { "type": "string" },
        "creationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "adminUserId", "targetCapital", "totalInstallments", "installmentValue", "subscriptionFeeRate", "administrativeFeeRate", "lifeInsuranceRate", "drawMethodCount", "bidMethodCount", "memberCapacity", "currentMemberCount", "status", "isPrivate", "creationDate"]
    },
    "SavingCircleMembership": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SavingCircleMembership",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "savingCircleId": { "type": "string" },
        "savingCircleName": { "type": "string" },
        "joiningDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "paidInstallmentsCount": { "type": "number" },
        "capitalPaid": { "type": "number" },
        "outstandingCapitalBalance": { "type": "number" },
        "adjudicationStatus": { "type": "string", "enum": ["Pending", "Adjudicated", "Completed"] }
      },
      "required": ["id", "userId", "savingCircleId", "joiningDate", "status", "paidInstallmentsCount", "capitalPaid", "outstandingCapitalBalance", "adjudicationStatus"]
    },
    "AdjudicationBid": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdjudicationBid",
      "type": "object",
      "description": "User offer to prepay installments to get adjudicated.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "savingCircleId": { "type": "string" },
        "membershipId": { "type": "string" },
        "installmentsOffered": { "type": "number" },
        "amountInUsd": { "type": "number" },
        "bidDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Won", "Lost"] }
      },
      "required": ["id", "userId", "savingCircleId", "membershipId", "installmentsOffered", "amountInUsd", "bidDate", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/saving_circles/{savingCircleId}": {
      "schema": { "$ref": "#/backend/entities/SavingCircle" },
      "description": "Saving circles configuration."
    },
    "/saving_circles/{savingCircleId}/bids/{bidId}": {
      "schema": { "$ref": "#/backend/entities/AdjudicationBid" },
      "description": "Bids placed for a specific circle."
    },
    "/users/{userId}/saving_circle_memberships/{membershipId}": {
      "schema": { "$ref": "#/backend/entities/SavingCircleMembership" },
      "description": "User memberships."
    }
  }
}
