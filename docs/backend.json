
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the Círculo de Ahorro application. This entity stores basic profile information for each participant.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user, used for communication and identification. (Format: email)",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "The phone number of the user. (Optional)"
        },
        "address": {
          "type": "string",
          "description": "The physical address of the user. (Optional)"
        },
        "registrationDate": {
          "type": "string",
          "description": "The date and time when the user registered in the application. (Format: date-time)",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "email",
        "registrationDate"
      ]
    },
    "SavingCircle": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SavingCircle",
      "type": "object",
      "description": "Represents a collective saving circle (Círculo de Ahorro) with specific financial parameters in USD.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the SavingCircle entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the saving circle."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the saving circle."
        },
        "adminUserId": {
          "type": "string",
          "description": "Reference to the Admin User."
        },
        "targetCapital": {
          "type": "number",
          "description": "Capital suscripto (multiplo de 5000 USD)."
        },
        "totalInstallments": {
          "type": "number",
          "description": "Cantidad de cuotas (multiplo de 12)."
        },
        "installmentValue": {
          "type": "number",
          "description": "Alicuota (capital / cuotas)."
        },
        "subscriptionFeeRate": {
          "type": "number",
          "description": "Derecho de suscripción (0.01-0.10)."
        },
        "administrativeFeeRate": {
          "type": "number",
          "description": "Gasto administrativo (0.01-0.10)."
        },
        "lifeInsuranceRate": {
          "type": "number",
          "description": "Seguro de vida (fijo 0.0009)."
        },
        "drawMethodCount": {
          "type": "number",
          "description": "Adjudicaciones por sorteo por ronda (1-5)."
        },
        "bidMethodCount": {
          "type": "number",
          "description": "Adjudicaciones por licitación por ronda (1-5)."
        },
        "memberCapacity": {
          "type": "number",
          "description": "Total miembros = cuotas * (sorteo + licitacion)."
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Active", "Completed", "Cancelled"]
        },
        "creationDate": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "adminUserId",
        "targetCapital",
        "totalInstallments",
        "installmentValue",
        "subscriptionFeeRate",
        "administrativeFeeRate",
        "lifeInsuranceRate",
        "drawMethodCount",
        "bidMethodCount",
        "memberCapacity",
        "status",
        "creationDate"
      ]
    },
    "SavingCircleMembership": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SavingCircleMembership",
      "type": "object",
      "description": "User's individual subscription and progress.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "savingCircleId": { "type": "string" },
        "joiningDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "paidInstallmentsCount": { "type": "number" },
        "capitalPaid": { "type": "number" },
        "outstandingCapitalBalance": { "type": "number", "description": "Saldo de capital: Capital Suscripto - alicuotas pagas." },
        "adjudicationStatus": { "type": "string" }
      },
      "required": [
        "id",
        "userId",
        "savingCircleId",
        "joiningDate",
        "status",
        "paidInstallmentsCount",
        "capitalPaid",
        "outstandingCapitalBalance",
        "adjudicationStatus"
      ]
    },
    "Payment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Payment",
      "type": "object",
      "description": "Detailed payment record including all fees.",
      "properties": {
        "id": { "type": "string" },
        "savingCircleMembershipId": { "type": "string" },
        "installmentNumber": { "type": "number" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "baseInstallmentAmountComponent": { "type": "number", "description": "Alicuota pura." },
        "subscriptionFeeComponent": { "type": "number" },
        "administrativeFeeComponent": { "type": "number" },
        "lifeInsuranceComponent": { "type": "number" },
        "latePaymentInterestAmount": { "type": "number" },
        "totalPaidAmount": { "type": "number", "description": "Cuota total pagada." },
        "status": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" }
      },
      "required": [
        "id",
        "savingCircleMembershipId",
        "installmentNumber",
        "paymentDate",
        "baseInstallmentAmountComponent",
        "subscriptionFeeComponent",
        "administrativeFeeComponent",
        "lifeInsuranceComponent",
        "totalPaidAmount",
        "status",
        "dueDate"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/saving_circles/{savingCircleId}",
        "definition": {
          "entityName": "SavingCircle",
          "schema": { "$ref": "#/backend/entities/SavingCircle" },
          "description": "Saving circles configuration in USD."
        }
      },
      {
        "path": "/users/{userId}/saving_circle_memberships/{membershipId}",
        "definition": {
          "entityName": "SavingCircleMembership",
          "schema": { "$ref": "#/backend/entities/SavingCircleMembership" },
          "description": "User memberships and capital balance tracking."
        }
      }
    ]
  }
}
